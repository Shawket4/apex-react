{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main app window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:app:default",
    "core:event:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://apextransport.ddns.net/**" }
      ]
    }
  ]
}
